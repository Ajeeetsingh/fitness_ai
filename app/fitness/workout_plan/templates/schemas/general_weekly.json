{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "General Weekly Workout Plan",
  "type": "object",
  "required": ["provided_information", "summary", "days", "metadata"],
  "properties": {
    "provided_information": {
      "type": "object",
      "required": ["goal", "minutes", "experience", "equipment_list"],
      "properties": {
        "user_id": {"type": ["string", "null"]},
        "goal": {"type": "string", "minLength": 1},
        "minutes": {"type": "integer", "minimum": 5, "maximum": 180},
        "experience": {"type": "string", "enum": ["beginner", "intermediate", "advanced"]},
        "equipment_list": {"type": "array", "items": {"type": "string"}},
        "sport": {"type": "string", "default": "general_fitness"},
        "style": {"type": "string", "default": "mixed"},
        "language": {"type": "string", "default": "en"},
        "availability": {"type": ["object", "null"]},
        "preferred_days": {"type": ["array", "null"]},
        "rest_days": {"type": ["array", "null"]},
        "injuries": {"type": ["array", "object", "null"]},
        "allow_substitutions": {"type": ["boolean", "null"]}
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "plan_meta": {
      "type": "object",
      "properties": {
        "plan_type": {"type": "string", "const": "weekly"},
        "weekly_sessions": {"type": "integer", "minimum": 1, "maximum": 7, "default": 5},
        "start_date_iso": {"type": ["string", "null"], "format": "date"},
        "end_date_iso": {"type": ["string", "null"], "format": "date"},
        "strict": {"type": "boolean", "default": false}
      }
    },
    "days": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^day_[1-7]$": {
          "type": "object",
          "required": ["warmup", "main_session", "cooldown"],
          "properties": {
            "warmup": {
              "type": "object",
              "required": ["duration_minutes", "exercises"],
              "properties": {
                "duration_minutes": {"type": ["integer", "null"], "minimum": 0},
                "exercises": {"type": "array"}
              }
            },
            "main_session": {
              "type": "object",
              "required": ["duration_minutes", "exercises"],
              "properties": {
                "duration_minutes": {"type": ["integer", "null"], "minimum": 0},
                "exercises": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": ["name"],
                    "properties": {
                      "name": {"type": "string"},
                      "sets": {"type": ["integer", "null"]},
                      "reps": {"type": ["integer", "null"]},
                      "work_seconds": {"type": ["integer", "null"]},
                      "rest_seconds": {"type": ["integer", "null"]},
                      "intensity": {"type": ["string", "null"]}
                    }
                  }
                },
                "time_budget_check": {"type": ["string", "null"]}
              }
            },
            "cooldown": {
              "type": "object",
              "required": ["duration_minutes", "exercises"],
              "properties": {
                "duration_minutes": {"type": ["integer", "null"], "minimum": 0},
                "exercises": {"type": "array"}
              }
            }
          }
        }
      }
    },
    "suggestions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "diet_plan": {
      "type": "object"
    },
    "metadata": {
      "type": "object",
      "required": [],
      "properties": {
        "generated_by": {"type": "string"},
        "input_received": {"type": "object"},
        "auto_filled_fields": {
          "type": "array",
          "maxItems": 6,
          "items": {"type": "string"}
        },
        "repaired_by": {"type": ["string", "null"]},
        "generation_timestamp_iso": {"type": ["string", "null"]}
      }
    }
  }
}

