{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "General Daily Workout Plan",
  "type": "object",
  "required": ["provided_information", "summary", "day_1", "metadata"],
  "properties": {
    "provided_information": {
      "type": "object",
      "required": ["goal", "minutes", "experience", "equipment_list"],
      "properties": {
        "user_id": {"type": ["string", "null"]},
        "goal": {"type": "string", "minLength": 1},
        "minutes": {"type": "integer", "minimum": 5, "maximum": 180},
        "experience": {"type": "string", "enum": ["beginner", "intermediate", "advanced"]},
        "equipment_list": {"type": "array", "items": {"type": "string"}},
        "sport": {"type": "string", "default": "general_fitness"},
        "style": {"type": "string", "default": "mixed"},
        "language": {"type": "string", "default": "en"}
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "plan_meta": {
      "type": "object",
      "properties": {
        "plan_type": {"type": "string", "const": "daily"}
      }
    },
    "day_1": {
      "type": "object",
      "required": ["warmup", "main_session", "cooldown"],
      "properties": {
        "warmup": {
          "type": "object",
          "required": ["duration_minutes", "exercises"],
          "properties": {
            "duration_minutes": {"type": ["integer", "null"], "minimum": 0},
            "exercises": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": {"type": "string"},
                  "sets": {"type": ["integer", "null"]},
                  "reps": {"type": ["integer", "null"]},
                  "work_seconds": {"type": ["integer", "null"]},
                  "rest_seconds": {"type": ["integer", "null"]},
                  "intensity": {"type": ["string", "null"]}
                }
              }
            }
          }
        },
        "main_session": {
          "type": "object",
          "required": ["duration_minutes", "exercises"],
          "properties": {
            "duration_minutes": {"type": ["integer", "null"], "minimum": 0},
            "exercises": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": {"type": "string"},
                  "sets": {"type": ["integer", "null"]},
                  "reps": {"type": ["integer", "null"]},
                  "work_seconds": {"type": ["integer", "null"]},
                  "rest_seconds": {"type": ["integer", "null"]},
                  "intensity": {"type": ["string", "null"]}
                }
              }
            },
            "time_budget_check": {"type": ["string", "null"]}
          }
        },
        "cooldown": {
          "type": "object",
          "required": ["duration_minutes", "exercises"],
          "properties": {
            "duration_minutes": {"type": ["integer", "null"], "minimum": 0},
            "exercises": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": {"type": "string"},
                  "sets": {"type": ["integer", "null"]},
                  "reps": {"type": ["integer", "null"]},
                  "work_seconds": {"type": ["integer", "null"]},
                  "rest_seconds": {"type": ["integer", "null"]},
                  "intensity": {"type": ["string", "null"]}
                }
              }
            }
          }
        }
      }
    },
    "suggestions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "diet_plan": {
      "type": "object"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "generated_by": {"type": "string"},
        "auto_filled_fields": {
          "type": "array",
          "maxItems": 6
        }
      }
    }
  }
}

